# === SERVER ===

# Go server listen port
PORT=3000

# === APPLICATION ===

# Display name used in <title> and <meta>
APP_NAME="Konsulin"

# Public URL of this app. If starts with https://
# Secure flag is set on all auth/CSRF cookies
APP_URL="http://localhost:3000"

# Path prefix for auth handling
AUTH_PATH="/auth"

# === BACKEND (FHIR API) ===

# Backend FHIR API base URL
# Scheme checked by tryBackendLogout — blocks HTTP in production
API_URL="http://localhost:3200"

# Path prefix added to backend API calls
API_BASE_PATH="/api/v1"

# Legacy; same as API_URL
NEXT_PUBLIC_API_URL="http://localhost:3200"

# === TERMINOLOGY SERVER ===

# FHIR terminology server (ValueSet, etc.)
TX_URL="http://localhost:3300"

# Legacy; same as TX_URL
NEXT_PUBLIC_TX_URL="http://localhost:3300"

# === SESSION / AUTH COOKIE ===

# Secret used to derive HMAC + encryption keys for gorilla/securecookie
# Must be stable across restarts — changing it invalidates existing cookies
# Minimum 32 chars recommended
SESSION_COOKIE_SECRET="CHANGE_ME_generate_a_random_64_char_secret"

# === CSRF PROTECTION ===

# 32+ byte key for gorilla/csrf token signing
# Leave empty to DISABLE CSRF middleware (safe default during transition)
# Set to a random 32-char value to enable protection on all state-changing
# Go SSR routes (POST/PUT/DELETE)
CSRF_AUTH_KEY=""

# === TRANSITION FLAGS ===

# If non-empty, ExtractFromRequest still accepts unsigned JSON auth cookies
# Set to "true" during migration, then clear after confirming zero hits
ALLOW_UNSIGNED_COOKIES=""

# If non-empty, tryBackendLogout forwards cookies to HTTP backend URLs
# Set to "true" for local dev with HTTP backend
# Leave empty in production — only HTTPS allowed
ALLOW_INSECURE_BACKEND_LOGOUT=""

# === NEXT.JS PROXY ===

# Target URL for the Next.js reverse proxy
# Unmatched routes fall through to this
NEXTJS_URL="http://localhost:8080"

# === LOGGING ===

# Log level: DEBUG, INFO, WARN, ERROR
LOG="DEBUG"
