#!/usr/bin/env sh
#. "$(dirname -- "$0")/_/husky.sh" # Removed: Will fail in v10.0.0

# mise manages Go, templ, golangci-lint — ensure shims are on PATH
export PATH="$HOME/.local/share/mise/shims:$PATH"

make check-go && go test ./... -count=1 && make docker-check || exit 1

# Lint staged JS/TS files — fail commit on any error
if ! npx --no-install lint-staged; then
  echo "  Linting failed. Fix errors and try again."
  exit 1
fi
