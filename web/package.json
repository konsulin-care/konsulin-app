{
  "name": "konsulin-web-spas",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i static/css/templ-input.css -o static/css/output.css --content '../template/**/*.templ'",
    "build:js": "mkdir -p static/js && cp node_modules/alpinejs/dist/cdn.min.js static/js/alpine.min.js && cp node_modules/htmx.org/dist/htmx.min.js static/js/htmx.min.js",
    "build:auth-spa": "tsc --noEmit -p auth-spa/tsconfig.json && vite build auth-spa",
    "build": "npm run build:css && npm run build:js && npm run build:auth-spa"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "supertokens-auth-react": "^0.51.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "alpinejs": "^3.14.9",
    "htmx.org": "^2.0.9",
    "@tailwindcss/cli": "^4.3.0",
    "@types/fhir": "^0.0.43",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
